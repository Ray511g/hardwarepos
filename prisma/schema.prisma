generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  name            String
  description     String?
  category        String
  unit            String   // KG, Bag, Piece, Meter
  unitPrice       Float
  costPrice       Float
  stockLevel      Float    @default(0)
  minStockLevel   Float    @default(0)
  bulkDiscountPrice Float?
  bulkThreshold     Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  auditLogs       StockAudit[]
}

model Sale {
  id              String   @id @default(cuid())
  invoiceNumber   String   @unique
  total           Float
  taxAmount       Float    // VAT 16%
  discount        Float    @default(0)
  paymentMethod   String   // CASH, MPESA, CREDIT
  mpesaCode       String?
  
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  status          String   @default("COMPLETED")
  etimsSigned     Boolean  @default(false)
  etimsSignature  String?
  createdAt       DateTime @default(now())
  
  saleItems       SaleItem[]
  payments        Payment[]
}

model SaleItem {
  id              String   @id @default(cuid())
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Float
  unitPrice       Float
  costPrice       Float    @default(0) // Track cost at time of sale for profit logic
  subtotal        Float
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id])
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, RECEIVED, CANCELLED
  receivedAt      DateTime?
  createdAt       DateTime @default(now())
  items           PurchaseItem[]
}

model PurchaseItem {
  id              String   @id @default(cuid())
  orderId         String
  order           PurchaseOrder @relation(fields: [orderId], references: [id])
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  quantity        Float
  costPrice       Float
  subtotal        Float
}

model Customer {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  email           String?
  debtBalance     Float    @default(0)
  creditLimit     Float?   @default(50000)
  sales           Sale[]
  payments        Payment[]
  createdAt       DateTime @default(now())
}

model Payment {
  id              String   @id @default(cuid())
  amount          Float
  method          String   // CASH, MPESA
  reference       String?  // Mpesa code
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  saleId          String?
  sale            Sale?     @relation(fields: [saleId], references: [id])
  createdAt       DateTime @default(now())
}

model Expense {
  id              String   @id @default(cuid())
  category        String   // RENT, SALARY, ELECTRICITY, TRANSPORT, OTHER
  description     String
  amount          Float
  date            DateTime @default(now())
  recordedBy      String?
}

model StockAudit {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  systemStock     Float
  physicalStock   Float
  variance        Float
  reason          String?
  auditDate       DateTime @default(now())
}

model Supplier {
  id              String   @id @default(cuid())
  name            String
  contactPerson   String?
  phone           String?
  email           String?
  address         String?
  purchaseOrders  PurchaseOrder[]
  createdAt       DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("CASHIER")
  createdAt DateTime @default(now())
}

model BusinessSettings {
  id            String   @id @default("singleton")
  name          String   @default("Hardware Pro")
  phone         String?
  email         String?
  address       String?
  pinNumber     String?
  paybillNumber String?
  tillNumber    String?
  updatedAt     DateTime @updatedAt
}
